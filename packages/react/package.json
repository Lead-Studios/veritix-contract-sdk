{
  "name": "@veritix/contract-sdk-react",
  "version": "0.1.0",
  "description": "React hooks for the VeriTix contract SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/**/*"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts"
  },
  "peerDependencies": {
    "react": ">=18",
    "@veritix/contract-sdk": "*"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "@types/react": "^18.3.3",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  },
  "license": "MIT"
}
